{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "xingJobo portfolio — Zola static site",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xingJobo/Portfolio.git"
  },
  "license": "ISC",
  "scripts": {
    "lint:scss": "stylelint --allow-empty-input \"sass/**/*.{scss,sass}\"",
